# ==============================================
# Pokedex Data Platform — Environment Variables
# ==============================================
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real values.

# --- Ingestion Settings ---
# Number of Pokemon to ingest (0 = all, 151 = Gen 1 only)
POKEMON_LIMIT=151

# --- Destination Settings ---
# Pipeline destination: "duckdb" (local dev) or "bigquery" (cloud prod)
# Default: duckdb (when unset, the pipeline uses DuckDB)
PIPELINE_DESTINATION=duckdb

# --- GCP Settings (required only when PIPELINE_DESTINATION=bigquery) ---
# Google Cloud project ID
GCP_PROJECT_ID=your-gcp-project-id

# GCP region for BigQuery and GCS
GCP_LOCATION=us-central1

# GCS bucket name for dlt staging files (must match Terraform-provisioned bucket)
GCS_BUCKET_NAME=your-project-id-pokedex-dlt-staging
